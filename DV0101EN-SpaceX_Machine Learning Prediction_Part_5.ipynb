/span\u003emarkdown\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","      \u003cspan class=\"pl-ent\"\u003e\u0026quot;source\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eMost unsuccessful landings are planed. Space X; performs a controlled landing in the oceans.\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","      \u003cspan class=\"pl-ent\"\u003e\u0026quot;metadata\u0026quot;\u003c/span\u003e: {}","    },","    {","      \u003cspan class=\"pl-ent\"\u003e\u0026quot;cell_type\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003emarkdown\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","      \u003cspan class=\"pl-ent\"\u003e\u0026quot;source\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e## Objectives\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","      \u003cspan class=\"pl-ent\"\u003e\u0026quot;metadata\u0026quot;\u003c/span\u003e: {}","    },","    {","      \u003cspan class=\"pl-ent\"\u003e\u0026quot;cell_type\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003emarkdown\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","      \u003cspan class=\"pl-ent\"\u003e\u0026quot;source\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003ePerform exploratory  Data Analysis and determine Training Labels\u003cspan class=\"pl-cce\"\u003e\\n\\n\u003c/span\u003e*   create a column for the class\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e*   Standardize the data\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e*   Split into training data and test data\u003cspan class=\"pl-cce\"\u003e\\n\\n\\\\\u003c/span\u003e-Find best Hyperparameter for SVM, Classification Trees and Logistic Regression\u003cspan class=\"pl-cce\"\u003e\\n\\n\u003c/span\u003e*   Find the method performs best using test data\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","      \u003cspan class=\"pl-ent\"\u003e\u0026quot;metadata\u0026quot;\u003c/span\u003e: {}","    },","    {","      \u003cspan class=\"pl-ent\"\u003e\u0026quot;cell_type\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003emarkdown\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","      \u003cspan class=\"pl-ent\"\u003e\u0026quot;source\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e## Import Libraries and Define Auxiliary Functions\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","      \u003cspan class=\"pl-ent\"\u003e\u0026quot;metadata\u0026quot;\u003c/span\u003e: {}","    },","    {","      \u003cspan class=\"pl-ent\"\u003e\u0026quot;cell_type\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003ecode\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","      \u003cspan class=\"pl-ent\"\u003e\u0026quot;source\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eimport piplite\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003eawait piplite.install([\u0026#39;numpy\u0026#39;])\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003eawait piplite.install([\u0026#39;pandas\u0026#39;])\u00
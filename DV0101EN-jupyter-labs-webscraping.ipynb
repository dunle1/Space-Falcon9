"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;]\u0026lt;/span\u0026gt;\u0026lt;/a\u0026gt;\u0026lt;/sup\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","      \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;/td\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","      \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;td\u0026gt;\u0026lt;a href=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e/wiki/Cape_Canaveral_Space_Force_Station\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e title=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eCape Canaveral Space Force Station\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;Cape Canaveral\u0026lt;/a\u0026gt;,\u0026lt;br/\u0026gt;\u0026lt;a href=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e/wiki/Cape_Canaveral_Space_Launch_Complex_40\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e title=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eCape Canaveral Space Launch Complex 40\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;LC-40\u0026lt;/a\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","      \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;/td\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","      \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;td\u0026gt;\u0026lt;a class=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c
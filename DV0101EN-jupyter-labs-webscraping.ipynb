pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","      \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;/td\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","      \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;td class=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003etable-failure\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e style=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003ebackground: #FFC7C7; color:black; vertical-align: middle; text-align: center;\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;Failure\u0026lt;sup class=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003ereference\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e id=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003ecite_ref-nyt-20150628_100-0\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;\u0026lt;a href=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e#cite_note-nyt-20150628-100\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;\u0026lt;span class=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003ecite-bracket\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;[\u0026lt;/span\u0026gt;93\u0026lt;span class=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003ecite-bracket\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;]\u0026lt;/span\u0026gt;\u0026lt;/a\u0026gt;\u0026lt;/sup\u0026gt;\u0026lt;br/\u0026gt;\u0026lt;small\u0026gt;(in flight)\u0026lt;/small\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","      \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u0
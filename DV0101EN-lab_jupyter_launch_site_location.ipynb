pe\": \"markdown\",","      \"source\": \"Your updated map with distance line should look like the following screenshot:\\n\",","      \"metadata\": {}","    },","    {","      \"cell_type\": \"markdown\",","      \"source\": \"\u003ccenter\u003e\\n    \u003cimg src=\\\"https://cf-courses-data.s3.us.cloud-object-storage.appdomain.cloud/IBM-DS0321EN-SkillsNetwork/labs/module_3/images/launch_site_marker_distance.png\\\"\u003e\\n\u003c/center\u003e\\n\",","      \"metadata\": {}","    },","    {","      \"cell_type\": \"markdown\",","      \"source\": \"*TODO:* Similarly, you can draw a line betwee a launch site to its closest city, railway, highway, etc. You need to use `MousePosition` to find the their coordinates on the map first\\n\",","      \"metadata\": {}","    },","    {","      \"cell_type\": \"markdown\",","      \"source\": \"A railway map symbol may look like this:\\n\",","      \"metadata\": {}","    },","    {","      \"cell_type\": \"markdown\",","      \"source\": \"\u003ccenter\u003e\\n    \u003cimg src=\\\"https://cf-courses-data.s3.us.cloud-object-storage.appdomain.cloud/IBM-DS0321EN-SkillsNetwork/labs/module_3/images/railway.png\\\"\u003e\\n\u003c/center\u003e\\n\",","      \"metadata\": {}","    },","    {","      \"cell_type\": \"markdown\",","      \"source\": \"A highway map symbol may look like this:\\n\",","      \"metadata\": {}","    },","    {","      \"cell_type\": \"markdown\",","      \"source\": \"\u003ccenter\u003e\\n    \u003cimg src=\\\"https://cf-courses-data.s3.us.cloud-object-storage.appdomain.cloud/IBM-DS0321EN-SkillsNetwork/labs/module_3/images/highway.png\\\"\u003e\\n\u003c/center\u003e\\n\",","      \"metadata\": {}","    },","    {","      \"cell_type\": \"markdown\",","      \"source\": \"A city map symbol may look like this:\\n\",","      \"metadata\": {}","    },","    {","      \"cell_type\": \"markdown\",","      \"source\": \"\u003ccenter\u003e\\n    \u003cimg src=\\\"https://cf-courses-data.s3.us.cloud-object-storage.appdomain.cloud/IBM-DS0321EN-SkillsNetwork/labs/module_3/images/city.png\\\"\u003e\\n\u003c/center\u003e\\n\",","      \"metadata\": {}","    },","    {","      \"cell_type\": \"code\",","      \"source\": \"# Create a marker with distance to a closest city, railway, highway, etc.\\n# Draw a line between the marker to the launch site\\n\\n\\n# Closest city coordinate (found using MousePosition)\\ncity_lat = 28.572872\\ncity_lon = -80.648980\\n\\n# Calculate distance\\ndistance_city = calculate_distance(\\n    launch_site_lat,\\n    launch_site_lon,\\n    city_lat,\\n    city_lon\\n)\\n\\n# City marker\\ncity_marker = folium.Marker(\\n    [city_lat, city_lon],\\n    icon=DivIcon(\\n        icon_size=(20,20),\\n        icon_anchor=(0,0),\\n        html='\u003cdiv style=\\\"font-size: 12; color:#2ecc71;\\\"\u003e\u003cb\u003e%s\u003c/b\u003e\u003c/div\u003e'\\n        % \\\"{:10.2f} KM\\\".format(distance_city),\\n    )\\n)\\n\\nsite_map.add_child(city_marker)\\n\\n# Line to city\\ncity_line = folium.PolyLine(\\n    locations=[\\n        [launch_site_lat, launch_site_lon],\\n        [city_lat, city_lon]\\n    ],\\n    weight=1\\n)\\n\\nsite_map.add_child(city_line)\\n\",","      \"metadata\": {","        \"trusted\": true","      },","      \"outputs\": [","        {","          \"execution_count\": 58,","          \"output_type\": \"execute_result\",","          \"data\": {","            \"text/plain\": \"\u003cfolium.folium.Map at 0x6864568\u003e\",","            \"text/html\": \"\u003cdiv style=\\\"width:100%;\\\"\u003e\u003cdiv style=\\\"position:relative;width:100%;height:0;padding-bottom:60%;\\\"\u003e\u003cspan style=\\\"color:#565656\\\"\u003eMake this Notebook Trusted to load map: File -\u003e Trust Notebook\u003c/span\u003e\u003ciframe srcdoc=\\\"\u0026lt;!DOCTYPE html\u0026gt;\\n\u0026lt;html\u0026gt;\\n\u0026lt;head\u0026gt;\\n    \\n    \u0026lt;meta http-equiv=\u0026quot;content-type\u0026quot; content=\u0026quot;text/html; charset=UTF-8\u0026quot; /\u002
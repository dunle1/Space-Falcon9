uot;: \u0026quot;# Task 2: Mark the success/failed launches for each site on the map\\n\\n\\n\\n#initialize the map\\n\\nsite_map = folium.Map(location=nasa_coordinate, zoom_start=5)\\n\\n# Create a MarkerCluster object\\nmarker_cluster = MarkerCluster().add_to(site_map)\\n\\n\\nfor index, row in spacex_df.iterrows():\\n    # Determine marker color based on launch outcome\\n    if row[\u0026#39;class\u0026#39;] == 1:\\n        marker_color = \u0026#39;green\u0026#39;\\n        launch_outcome = \u0026#39;Success\u0026#39;\\n    else:\\n        marker_color = \u0026#39;red\u0026#39;\\n        launch_outcome = \u0026#39;Failure\u0026#39;\\n\\n    folium.CircleMarker(\\n        location=[row[\u0026#39;Lat\u0026#39;], row[\u0026#39;Long\u0026#39;]],\\n        radius=5,\\n        color=marker_color,\\n        fill=True,\\n        fill_color=marker_color,\\n        fill_opacity=0.7,\\n        popup=f\\\u0026quot;{row[\u0026#39;Launch Site\u0026#39;]}\u0026lt;br\u0026gt;{launch_outcome}\\\u0026quot;\\n    ).add_to(marker_cluster)\\n\\n# Display the map\\nsite_map\\n\u0026quot;,","      \u0026quot;metadata\u0026quot;: {","        \u0026quot;trusted\u0026quot;: true","      },","      \u0026quot;outputs\u0026quot;: [","        {","          \u0026quot;execution_count\u0026quot;: 47,","          \u0026quot;output_type\u0026quot;: \u0026quot;execute_result\u0026quot;,","          \u0026quot;data\u0026quot;: {","            \u0026quot;text/plain\u0026quot;: \u0026quot;\u0026lt;folium.folium.Map at 0x6864568\u0026gt;\u0026quot;,","            \u0026quot;text/html\u0026quot;: \u0026quot;\u0026lt;div style=\\\u0026quot;width:100%;\\\u0026quot;\u0026gt;\u0026lt;div style=\\\u0026quot;position:relative;width:100%;height:0;padding-bottom:60%;\\\u0026quot;\u0026gt;\u0026lt;span style=\\\u0026quot;color:#565656\\\u0026quot;\u0026gt;Make this Notebook Trusted to load map: File -\u0026gt; Trust Notebook\u0026lt;/span\u0026gt;\u0026lt;iframe srcdoc=\\\u0026quot;\u0026amp;lt;!DOCTYPE html\u